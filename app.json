{
  "expo": {
    "name": "Foodie",
    "slug": "food-delivery-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/restaurantLOGO.png",
    "scheme": "foodie",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo/restaurantLOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodie.delivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby delivery options.",
        "NSCameraUsageDescription": "Upload profile pictures and chat images.",
        "NSSpeechRecognitionUsageDescription": "Use your voice to cleanly search for delicious food items without typing instantly.",
        "NSMicrophoneUsageDescription": "Required to pick up your voice for hands-free dynamic product searching.",
        "LSApplicationQueriesSchemes": [
          "tez",
          "phonepe",
          "paytmmp",
          "bhim"
        ]
      }
    },
    "android": {
      "package": "com.foodie.delivery",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/logo/restaurantLOGO.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-speech-recognition",
      "./plugins/withUPIQueries",
      "./plugins/withAndroidResolvedDependencies",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FC8019"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85d4534d-3830-428e-a5b4-288491d68b29"
      }
    },
    "owner": "love.ble6072"
  }
}
